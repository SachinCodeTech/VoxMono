rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 3. Path Variable Hardening (ID Poisoning Guard)
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints (The "Anti-Update-Gap")
    function isValidTask(data) {
      return data.userId == request.auth.uid 
        && data.title is string && data.title.size() <= 1000
        && data.completed is bool
        && data.priority in ['low', 'medium', 'high'];
    }

    function isValidSettings(data) {
      return data.userId == request.auth.uid
        && data.theme in ['monochrome-light', 'monochrome-dark']
        && data.mindfulDelayEnabled is bool
        && data.showClock is bool
        && data.focusDuration is number
        && data.breakDuration is number
        && data.systemAppLinks is map
        && data.appOrder is list
        && data.blockedWebsites is list
        && data.customIcons is map;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      // Allow user to check their own root doc if it exists (though we don't use it yet)
      allow get: if isOwner(userId);
      
      match /tasks/{taskId} {
        allow get, delete: if isOwner(userId);
        allow list: if isOwner(userId);
        
        allow create: if isOwner(userId) 
          && isValidId(taskId) 
          && isValidTask(incoming());
          
        allow update: if isOwner(userId)
          && isValidTask(incoming())
          && incoming().userId == existing().userId;
      }
      
      match /settings/{settingsId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId); // Usually just one doc 'global'
        
        allow create: if isOwner(userId)
          && isValidId(settingsId)
          && isValidSettings(incoming());
          
        allow update: if isOwner(userId)
          && isValidSettings(incoming())
          && incoming().userId == existing().userId;
      }

      match /sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
